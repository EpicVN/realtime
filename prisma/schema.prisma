// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 1. Định nghĩa quyền hạn (Role) rõ ràng
// Dùng Enum giúp code không bao giờ bị lỗi chính tả kiểu "admin" vs "Admin"
enum Role {
  SUPER_ADMIN // Tài khoản trùm (không được đổi pass)
  ADMIN // Tài khoản thường
}

// 2. Model cho Contact Form (Khách hàng từ Web)
model Contact {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  company   String?
  interest  String? // VD: VoIP, CRM, AutoDialer
  message   String
  status    String   @default("PENDING") // PENDING, CALLED, CLOSED
  createdAt DateTime @default(now())
}

// 3. Model User (Dùng để Admin đăng nhập)
// Đã lược bỏ các bảng Account/Session vì ta dùng JWT Credentials
model User {
  id          String   @id @default(cuid())
  name        String?
  email       String   @unique
  password    String
  role        Role     @default(ADMIN)
  permissions String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// 4. Model Post (Bài viết trên Blog)
model Post {
  id          String   @id @default(uuid())
  title       String   @db.VarChar(100)
  slug        String   @unique
  description String?  @db.VarChar(160)
  content     String   @db.Text
  thumbnail   String?
  published   Boolean  @default(true)
  views       Int      @default(0)
  language    String   @default("vi")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// 5. Model SiteConfig (Cấu hình chung của website, chỉ có 1 record duy nhất)
model SiteConfig {
  id          String   @id @default("global") // Chỉ lưu 1 record duy nhất
  hotline     String   @default("0933119056")
  salePhone   String   @default("038 6923901")
  saleName    String   @default("Giang Lê")
  zaloLink    String   @default("https://zalo.me/0933119056")
  fbLink      String   @default("https://facebook.com/Realtime.vn")
  email       String   @default("sales@realtime.vn")
  address     String   @default("108/15/18 Đ. Số 1, Phường An Hội Đông, TP.HCM")
  updatedAt   DateTime @updatedAt
}

// Bảng quản lý Thông tin Doanh nghiệp/Khách hàng
model Company {
  id        String    @id @default(cuid())
  name      String    // Tên công ty (VD: Công ty TNHH Realtime)
  taxCode   String?   // Mã số thuế (Để xuất hóa đơn)
  isActive  Boolean   @default(true) // Trạng thái hoạt động của công ty
  licenses  License[] // Mối quan hệ: 1 Công ty sở hữu nhiều License
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

// Bảng quản lý bản quyền phần mềm (App C++)
model License {
  id          String    @id @default(cuid())
  key         String    @unique @db.VarChar(50) 
  hardwareId  String?   @db.VarChar(100)        
  
  // Khóa ngoại (Foreign Key) trỏ về bảng Company
  companyId   String
  company     Company   @relation(fields: [companyId], references: [id])
  
  isActive    Boolean   @default(true)          
  expiresAt   DateTime?                         
  activatedAt DateTime?                         
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}